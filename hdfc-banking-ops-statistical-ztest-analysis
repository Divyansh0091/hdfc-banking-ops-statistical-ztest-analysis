      "HYPOTHESIS TESTING RESULT\n",
      "Z-Calculated Value: 2.5686\n",
      "P-Value: 0.010210\n"
     ]
    }
   ],
   "source": [
    "z_cal,p_val = ztest(df_project['Old_Software_Speed_Hr'],df_project['New_Software_Speed_Hr']) \n",
    "print(\"\\nHYPOTHESIS TESTING RESULT\") \n",
    "print(f\"Z-Calculated Value: {z_cal:.4f}\") \n",
    "print(f\"P-Value: {p_val:4f}\") "
   ]
  },
  {
